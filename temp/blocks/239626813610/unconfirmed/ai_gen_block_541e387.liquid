{% doc %}
  @prompt
    countdown timer, make it small size, texts aligned, not big size, smaller texts, only hrs and mins and secs, without days, and make the section height more smaller, section height smaller and texts smaller, texts by side and timer by side so we make the section height smaller, texts on left and timer on right
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-countdown-timer-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.padding }}px;
    background-color: {{ block.settings.background_color }};
    border-radius: {% if block.settings.show_rounded_corners %}{{ block.settings.border_radius }}px{% else %}0{% endif %};
  }

  .ai-countdown-timer__container-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: {{ block.settings.gap }}px;
  }

  .ai-countdown-timer__text-{{ ai_gen_id }} {
    flex: 0 1 auto;
    text-align: left;
  }

  .ai-countdown-timer__heading-{{ ai_gen_id }} {
    margin: 0 0 {{ block.settings.text_spacing }}px;
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_size }}px;
    line-height: 1.2;
  }

  .ai-countdown-timer__subheading-{{ ai_gen_id }} {
    margin: 0;
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.subheading_size }}px;
    line-height: 1.3;
  }

  .ai-countdown-timer__display-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.box_spacing }}px;
    flex-shrink: 0;
    margin-left: auto;
  }

  .ai-countdown-timer__box-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-width: {{ block.settings.box_size }}px;
    padding: {{ block.settings.box_padding }}px;
    background-color: {{ block.settings.box_background_color }};
    border-radius: {% if block.settings.show_rounded_corners %}{{ block.settings.box_border_radius }}px{% else %}0{% endif %};
    {% if block.settings.show_box_border %}
      border: {{ block.settings.box_border_width }}px solid {{ block.settings.box_border_color }};
    {% endif %}
  }

  .ai-countdown-timer__number-{{ ai_gen_id }} {
    font-size: {{ block.settings.number_size }}px;
    font-weight: bold;
    color: {{ block.settings.number_color }};
    line-height: 1;
    margin-bottom: 2px;
  }

  .ai-countdown-timer__label-{{ ai_gen_id }} {
    font-size: {{ block.settings.label_size }}px;
    color: {{ block.settings.label_color }};
    {% if block.settings.label_uppercase %}
      text-transform: uppercase;
    {% endif %}
    letter-spacing: 0.05em;
    line-height: 1;
  }

  .ai-countdown-timer__expired-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.subheading_size }}px;
  }

  @media screen and (max-width: 749px) {
    .ai-countdown-timer__container-{{ ai_gen_id }} {
      flex-direction: column;
      align-items: flex-start;
    }

    .ai-countdown-timer__display-{{ ai_gen_id }} {
      margin-left: 0;
    }

    .ai-countdown-timer__box-{{ ai_gen_id }} {
      min-width: {{ block.settings.box_size | times: 0.8 }}px;
      padding: {{ block.settings.box_padding | times: 0.8 }}px;
    }

    .ai-countdown-timer__number-{{ ai_gen_id }} {
      font-size: {{ block.settings.number_size | times: 0.8 }}px;
    }

    .ai-countdown-timer__label-{{ ai_gen_id }} {
      font-size: {{ block.settings.label_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<countdown-timer-{{ ai_gen_id }}
  class="ai-countdown-timer-{{ ai_gen_id }}"
  data-end-date="{{ block.settings.end_date }}"
  data-end-time="{{ block.settings.end_time }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-countdown-timer__container-{{ ai_gen_id }}">
    <div class="ai-countdown-timer__text-{{ ai_gen_id }}">
      {% if block.settings.heading != blank %}
        <h2 class="ai-countdown-timer__heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
      {% endif %}

      {% if block.settings.subheading != blank %}
        <div class="ai-countdown-timer__subheading-{{ ai_gen_id }}">{{ block.settings.subheading }}</div>
      {% endif %}
    </div>

    <div class="ai-countdown-timer__display-{{ ai_gen_id }}">
      {% if block.settings.show_hours %}
        <div class="ai-countdown-timer__box-{{ ai_gen_id }}">
          <div class="ai-countdown-timer__number-{{ ai_gen_id }}" data-hours>00</div>
          <div class="ai-countdown-timer__label-{{ ai_gen_id }}">{{ block.settings.hours_label }}</div>
        </div>
      {% endif %}

      {% if block.settings.show_minutes %}
        <div class="ai-countdown-timer__box-{{ ai_gen_id }}">
          <div class="ai-countdown-timer__number-{{ ai_gen_id }}" data-minutes>00</div>
          <div class="ai-countdown-timer__label-{{ ai_gen_id }}">{{ block.settings.minutes_label }}</div>
        </div>
      {% endif %}

      {% if block.settings.show_seconds %}
        <div class="ai-countdown-timer__box-{{ ai_gen_id }}">
          <div class="ai-countdown-timer__number-{{ ai_gen_id }}" data-seconds>00</div>
          <div class="ai-countdown-timer__label-{{ ai_gen_id }}">{{ block.settings.seconds_label }}</div>
        </div>
      {% endif %}
    </div>
  </div>

  <div class="ai-countdown-timer__expired-{{ ai_gen_id }}" style="display: none;" data-expired>
    {{ block.settings.expired_message }}
  </div>
</countdown-timer-{{ ai_gen_id }}>

<script>
  (function() {
    class CountdownTimer{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.endDate = this.dataset.endDate;
        this.endTime = this.dataset.endTime;
        this.hoursEl = this.querySelector('[data-hours]');
        this.minutesEl = this.querySelector('[data-minutes]');
        this.secondsEl = this.querySelector('[data-seconds]');
        this.expiredEl = this.querySelector('[data-expired]');
        this.containerEl = this.querySelector('.ai-countdown-timer__container-{{ ai_gen_id }}');
        this.interval = null;
      }

      connectedCallback() {
        if (!this.endDate) {
          this.showExpired();
          return;
        }

        this.startCountdown();
      }

      disconnectedCallback() {
        if (this.interval) {
          clearInterval(this.interval);
        }
      }

      startCountdown() {
        this.updateCountdown();
        this.interval = setInterval(() => {
          this.updateCountdown();
        }, 1000);
      }

      updateCountdown() {
        const endDateTime = this.getEndDateTime();
        const now = new Date().getTime();
        const distance = endDateTime - now;

        if (distance < 0) {
          this.showExpired();
          return;
        }

        const totalHours = Math.floor(distance / (1000 * 60 * 60));
        const minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
        const seconds = Math.floor((distance % (1000 * 60)) / 1000);

        if (this.hoursEl) this.hoursEl.textContent = this.padZero(totalHours);
        if (this.minutesEl) this.minutesEl.textContent = this.padZero(minutes);
        if (this.secondsEl) this.secondsEl.textContent = this.padZero(seconds);
      }

      getEndDateTime() {
        let dateTimeString = this.endDate;
        if (this.endTime) {
          dateTimeString += ' ' + this.endTime;
        } else {
          dateTimeString += ' 23:59:59';
        }
        return new Date(dateTimeString).getTime();
      }

      padZero(num) {
        return num.toString().padStart(2, '0');
      }

      showExpired() {
        if (this.interval) {
          clearInterval(this.interval);
        }
        if (this.containerEl) {
          this.containerEl.style.display = 'none';
        }
        if (this.expiredEl) {
          this.expiredEl.style.display = 'block';
        }
      }
    }

    customElements.define('countdown-timer-{{ ai_gen_id }}', CountdownTimer{{ ai_gen_id }});
  })();
</script>

